APP_NAME=financial-lobster
ENVIRONMENT=local
LOG_LEVEL=INFO

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 额外推送：有人给机器人发消息时主动单聊提醒管理员；留空则关闭。
FEISHU_ADMIN_RECEIVE_ID=
FEISHU_ADMIN_RECEIVE_ID_TYPE=open_id

LOCAL_STORAGE_DIR=storage/uploads
TASK_STORAGE_DIR=storage/tasks
ANALYSIS_CACHE_DIR=storage/cache
EVENT_DEDUP_DIR=storage/events

# 上传门禁：单文件大小上限（MB）与可接受文件类型（逗号分隔，含点号）。
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=.pdf,.docx,.csv,.xlsx

LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
# 备用 chat 模型（逗号分隔，同账号）：主模型额度耗尽（欠费/insufficient_quota）时按序切换。
# 缓存不含模型名，换模型仍命中。留空=关闭，额度耗尽直接报错（切付费固定模型后清空即可）。
LLM_FALLBACK_MODELS=
LLM_TIMEOUT_MS=180000
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.2
LLM_CHUNK_CHARS=18000
LLM_MAX_PAGES=200            # 分析页数上限（绑定约束），超出则截断并提示，追问仍覆盖全文。
LLM_REDUCE_GROUP_SIZE=8      # 分层归并每组笔记数，避免一次性 reduce 爆上下文。
LLM_MAP_CONCURRENCY=4        # map 阶段并发 LLM 调用数（接口有速率限制，保守值）。
LLM_MAX_CHUNKS=200           # 防跑飞硬上限；真正的限制是 LLM_MAX_PAGES。
PROMPT_VERSION=material_financial_summary:v1

# ============ 追问问答（多轮对话）============
CONVERSATION_STORAGE_DIR=storage/conversations
QA_RECENT_FILES_MAX=5          # 每个用户最多记住最近 N 个文件，超出按 LRU 淘汰。
QA_RETRIEVE_TOP_K=5            # 文件内检索取相关度最高的前 K 个片段。
QA_CONTEXT_MAX_CHARS=24000     # 单次喂给模型的检索片段字符预算上限。
QA_HISTORY_MAX_TURNS=5         # 单文件追问携带的最近对话轮数上限。
QA_PROMPT_VERSION=material_qa:v1

# ============ 向量检索（embedding）============
# 中英混排材料靠多语言 embedding 做语义检索。
# embedding 可独立于 chat 走另一平台：以下两项留空则复用 LLM_BASE_URL / LLM_API_KEY（同账号），
# 填写则 embedding 请求改用该平台（仍需 OpenAI 兼容 /embeddings），chat 不受影响。
# 用途：chat 平台 embedding 额度耗尽，或想把向量算力分流到免费/独立账号时使用。
# 例（智谱 GLM，embedding-3 为 2048 维）：
#   QA_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   QA_EMBEDDING_API_KEY=<你的智谱 key>
#   QA_EMBEDDING_MODEL=embedding-3
QA_EMBEDDING_BASE_URL=
QA_EMBEDDING_API_KEY=
# 换 embedding 模型只影响新入库文件，旧缓存仍用各自记录的模型查询，故无需清空缓存目录。
QA_EMBEDDING_MODEL=text-embedding-v4   # 阿里百炼多语言向量模型。
# 备用 embedding 模型（逗号分隔，同账号）：入库时主模型额度耗尽则整文件改用下一个重算，
# 并把实际所用模型记入缓存；查询强制用该文件入库时的模型，避免跨模型向量空间错配。
# 只影响新入库文件；旧文件继续用各自缓存里记录的模型查询。留空=关闭。
QA_EMBEDDING_FALLBACK_MODELS=
QA_EMBEDDING_CHUNK_CHARS=700           # 切块字符数：检索粒度，小于整页以提升命中精度。
QA_EMBEDDING_CHUNK_OVERLAP=120         # 相邻块重叠字符，避免答案被切在块边界。
QA_EMBEDDING_BATCH_SIZE=10             # 单次 embedding 请求最大文本条数（接口上限）。
QA_EMBEDDING_CACHE_DIR=storage/embeddings  # 向量缓存目录，按 file_hash 命名。

# ============ 联网检索（行业研究）============
# SEARCH_API_KEY 留空则回退 QA_EMBEDDING_API_KEY（向后兼容原型配置）。
SEARCH_PROVIDER=zhipu
SEARCH_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SEARCH_API_KEY=
SEARCH_ENGINE=search_std
SEARCH_MAX_SOURCES=8
SEARCH_QUERIES_PER_SECTION=3
# 行业研究模板目录：扫描该目录下的 *.docx 作为可选模板，用户点击菜单后可点选
RESEARCH_TEMPLATE_DIR=storage/templates
# 兜底模板 docx 路径：当模板目录为空时回退使用（向后兼容旧单模板配置）
RESEARCH_TEMPLATE_PATH=

# ============ 会话 / 卡片回调 ============
SESSION_STORAGE_DIR=storage/sessions
CARD_EVENT_DEDUP_DIR=storage/card_events

# 技能开关（false 则不出现在能力卡）
ENABLE_INDUSTRY_RESEARCH=true
ENABLE_TEMPLATE_REWRITE=true
